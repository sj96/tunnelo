{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tunnelo",
  "version": "0.1.0",
  "identifier": "com.shi.tunnelo",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tunnelo",
        "width": 920,
        "height": 600,
        "minWidth": 640,
        "minHeight": 420,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
